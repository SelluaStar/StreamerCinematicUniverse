# Twitch Developer Console application credentials.
# Never prefix the secret with NEXT_PUBLIC_ and never commit .env.local.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Local development callback. Replace with your exact HTTPS URL in production.
TWITCH_REDIRECT_URI=http://localhost:3000/api/auth/callback/twitch
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Generate at least 32 random bytes, for example:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Supabase — Parcel DataBase (SCU)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional service role for rare server-only admin tasks
SUPABASE_SECRET_KEY=

# Notifications (Phase B)
RESEND_API_KEY=
EMAIL_FROM=SCU <onboarding@resend.dev>
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
CRON_SECRET=
TWITCH_EVENTSUB_SECRET=
